#!/usr/bin/env python3

import argparse
import sys
import time
from typing import Optional

import rclpy
from builtin_interfaces.msg import Time
from geometry_msgs.msg import PoseStamped
from moveit.planning import MoveItPy
from rclpy.duration import Duration
from rclpy.node import Node
from tf2_ros import Buffer, TransformException, TransformListener


PLANNING_GROUP = "fr3_arm"


def parse_arguments() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Relative Cartesian pose-goal motion for Franka FR3."
    )

    parser.add_argument("--dx", type=float, default=0.0)
    parser.add_argument("--dy", type=float, default=0.0)
    parser.add_argument("--dz", type=float, default=0.0)

    parser.add_argument(
        "--execute",
        type=str,
        default="false",
        help="Whether to execute the planned trajectory.",
    )

    parser.add_argument(
        "--base-frame",
        type=str,
        default="fr3_link0",
        help="Reference frame for dx, dy and dz.",
    )

    parser.add_argument(
        "--ee-link",
        type=str,
        default="fr3_hand_tcp",
        help="End-effector link.",
    )

    # Ignore ROS arguments automatically appended by ros2 launch.
    args, _ = parser.parse_known_args()
    return args


def parse_bool(value: str) -> bool:
    return value.strip().lower() in {
        "true",
        "1",
        "yes",
        "on",
    }


def wait_for_tcp_pose(
    node: Node,
    tf_buffer: Buffer,
    base_frame: str,
    ee_link: str,
    timeout_seconds: float = 10.0,
) -> PoseStamped:
    """Read the current end-effector pose from TF."""

    deadline = time.monotonic() + timeout_seconds
    last_error: Optional[Exception] = None

    while rclpy.ok() and time.monotonic() < deadline:
        try:
            transform = tf_buffer.lookup_transform(
                base_frame,
                ee_link,
                Time(),
                timeout=Duration(seconds=1.0),
            )

            pose = PoseStamped()
            pose.header.frame_id = base_frame
            pose.header.stamp = node.get_clock().now().to_msg()

            pose.pose.position.x = transform.transform.translation.x
            pose.pose.position.y = transform.transform.translation.y
            pose.pose.position.z = transform.transform.translation.z
            pose.pose.orientation = transform.transform.rotation

            return pose

        except TransformException as error:
            last_error = error
            node.get_logger().warning(
                f"Waiting for TF {base_frame} -> {ee_link}: {error}"
            )

    raise RuntimeError(
        f"Could not obtain TF {base_frame} -> {ee_link} "
        f"within {timeout_seconds:.1f} seconds. "
        f"Last error: {last_error}"
    )


def main() -> int:
    args = parse_arguments()
    execute_motion = parse_bool(args.execute)

    rclpy.init()

    helper_node = Node("fr3_cartesian_move_helper")
    tf_buffer = Buffer()

    # spin_thread=True lets the TF listener receive transforms
    # while MoveItPy is doing its own work.
    tf_listener = TransformListener(
        tf_buffer,
        helper_node,
        spin_thread=True,
    )

    moveit = None

    try:
        helper_node.get_logger().info(
            "Requested displacement in base frame:\n"
            f"  base frame = {args.base_frame}\n"
            f"  end link   = {args.ee_link}\n"
            f"  dx         = {args.dx:.4f} m\n"
            f"  dy         = {args.dy:.4f} m\n"
            f"  dz         = {args.dz:.4f} m\n"
            f"  execute    = {execute_motion}"
        )

        moveit = MoveItPy(
            node_name="fr3_cartesian_moveitpy"
        )

        arm = moveit.get_planning_component(
            PLANNING_GROUP
        )

        current_pose = wait_for_tcp_pose(
            node=helper_node,
            tf_buffer=tf_buffer,
            base_frame=args.base_frame,
            ee_link=args.ee_link,
        )

        target_pose = PoseStamped()
        target_pose.header.frame_id = args.base_frame
        target_pose.header.stamp = (
            helper_node.get_clock().now().to_msg()
        )

        # Relative translation in the selected base frame.
        target_pose.pose.position.x = (
            current_pose.pose.position.x + args.dx
        )
        target_pose.pose.position.y = (
            current_pose.pose.position.y + args.dy
        )
        target_pose.pose.position.z = (
            current_pose.pose.position.z + args.dz
        )

        # Preserve the current end-effector orientation.
        target_pose.pose.orientation = (
            current_pose.pose.orientation
        )

        helper_node.get_logger().info(
            "Current TCP position:\n"
            f"  x = {current_pose.pose.position.x:.4f}\n"
            f"  y = {current_pose.pose.position.y:.4f}\n"
            f"  z = {current_pose.pose.position.z:.4f}"
        )

        helper_node.get_logger().info(
            "Target TCP position:\n"
            f"  x = {target_pose.pose.position.x:.4f}\n"
            f"  y = {target_pose.pose.position.y:.4f}\n"
            f"  z = {target_pose.pose.position.z:.4f}"
        )

        arm.set_start_state_to_current_state()

        arm.set_goal_state(
            pose_stamped_msg=target_pose,
            pose_link=args.ee_link,
        )

        helper_node.get_logger().info(
            "Planning..."
        )

        plan_result = arm.plan()

        if not plan_result:
            helper_node.get_logger().error(
                "Planning failed."
            )
            return 1

        helper_node.get_logger().info(
            "Planning succeeded."
        )

        if not execute_motion:
            helper_node.get_logger().info(
                "Execution is disabled. "
                "Run with execute:=true to move the robot."
            )
            return 0

        helper_node.get_logger().warning(
            "Executing trajectory on the real robot..."
        )

        # An empty controller list lets MoveIt select
        # the configured default controller.
        execution_result = moveit.execute(
            plan_result.trajectory,
            controllers=[],
        )

        helper_node.get_logger().info(
            f"Execution result: {execution_result}"
        )

        return 0

    except Exception as error:
        helper_node.get_logger().error(
            f"MoveItPy error: {error}"
        )
        return 1

    finally:
        # Destroy MoveItPy before shutting down ROS.
        if moveit is not None:
            del moveit

        del tf_listener
        helper_node.destroy_node()

        if rclpy.ok():
            rclpy.shutdown()


if __name__ == "__main__":
    raise SystemExit(main())



